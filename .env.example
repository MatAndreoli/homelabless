# Copy this file to .env and fill in the real values.
# The real .env is in .gitignore and must never be committed.

# WSL host IP (the eth0 IP of your WSL2 distro, shown by `hostname -I`).
# Used in docker-compose.yml (extra_hosts) and the Caddyfile (via the
# caddy entrypoint script that substitutes {{WSL_HOST_IP}} placeholders).
# When this changes after a WSL reboot, just update this single line and
# restart the stack — no other file needs to be edited.
WSL_HOST_IP=replace_with_output_of_hostname_-I

# Portainer API access token — used by Homepage widget to query Portainer
# container stats. Generate at https://portainer.home -> User -> Access tokens.
# Leave blank if not using the Portainer widget.
PORTAINER_API_KEY=

# Beszel widget credentials (consumed by Homepage via HOMEPAGE_VAR_*
# env-var interpolation in services.yaml).
# USER/PASSWORD: an admin account on the hub (any role works).
# Reset via CLI: docker exec beszel-hub /beszel superuser update EMAIL PASS
# SYSTEM_ID: the Beszel internal ID of the system to show. Visible in
# the hub UI URL when viewing a system (e.g. /system/0mkfcfw9wmaf9cl).
BESZEL_USER=
BESZEL_PASSWORD=
BESZEL_SYSTEM_ID=

# Authelia secrets — substitute into authelia/configuration.yml via
# ${AUTHELIA_JWT_SECRET}, ${AUTHELIA_SESSION_SECRET},
# ${AUTHELIA_STORAGE_ENCRYPTION_KEY}. Generate with:
#   openssl rand -hex 32    (run 3 times, one per variable)
# All three are sensitive: leaking them allows forging sessions, password
# reset tokens, and decrypting stored 2FA secrets.
AUTHELIA_JWT_SECRET=
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=

# Beszel agent auth key. The agent uses this to verify the hub's
# signature when the hub dials the agent over the unix socket. It is
# the **hub's** public key — matches the private key in
# ./beszel-hub-data/id_ed25519 that the hub auto-generates on first
# start. The same value is shown in the hub UI's "Add System" dialog
# (click "Add System" then copy the public key it prints).
#
# Extract the current value at any time with:
#   docker run --rm -v $PWD/beszel-hub-data:/keys:ro alpine:latest \
#       sh -c "apk add --no-cache openssh >/dev/null && ssh-keygen -y -f /keys/id_ed25519"
#
# To rotate: delete beszel-hub-data/id_ed25519* (and this var), let the
# hub regenerate on next start, then update this var with the new
# public key. The agent won't be able to verify the hub's signature
# with the old key and the connection will fail.
BESZEL_AGENT_KEY=

# Beszel agent registration token. Per-system, generated when you click
# "Add System" in the hub UI. Same dialog shows the public key above
# and a TOKEN — copy both. Empty until first run.
BESZEL_AGENT_TOKEN=

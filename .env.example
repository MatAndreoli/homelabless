# Copy this file to .env and fill in the real values.
# The real .env is in .gitignore and must never be committed.

# WSL host IP (the eth0 IP of your WSL2 distro, shown by `hostname -I`).
# Used in docker-compose.yml (extra_hosts) and the Caddyfile (via the
# caddy entrypoint script that substitutes {{WSL_HOST_IP}} placeholders).
# When this changes after a WSL reboot, just update this single line and
# restart the stack — no other file needs to be edited.
WSL_HOST_IP=replace_with_output_of_hostname_-I

# Portainer API access token — used by Homepage widget to query Portainer
# container stats. Generate at https://portainer.homelab.less -> User -> Access tokens.
# Leave blank if not using the Portainer widget.
PORTAINER_API_KEY=

# Authelia secrets — substitute into authelia/configuration.yml via
# ${AUTHELIA_JWT_SECRET}, ${AUTHELIA_SESSION_SECRET},
# ${AUTHELIA_STORAGE_ENCRYPTION_KEY}. Generate with:
#   openssl rand -hex 32    (run 3 times, one per variable)
# All three are sensitive: leaking them allows forging sessions, password
# reset tokens, and decrypting stored 2FA secrets.
AUTHELIA_JWT_SECRET=
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=

# Copy this file to .env and fill in the real values.
# The real .env is in .gitignore and must never be committed.
#
# Generate a fresh SECRET_ENCRYPTION_KEY with:
#   openssl rand -hex 32
#
# WARNING: Rotating SECRET_ENCRYPTION_KEY will lock you out of all
# encrypted Homarr data (integration credentials, saved board configs).
# Only regenerate on a fresh homarr-data/ or after accepting data loss.

SECRET_ENCRYPTION_KEY=replace_me_with_output_of_openssl_rand_hex_32
